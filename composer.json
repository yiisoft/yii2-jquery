{
    "name": "yiisoft/yii2-jquery",
    "type": "yii2-extension",
    "description": "jQuery integration layer for Yii2 asset bundles, client validation scripts, and widget client scripts.",
    "keywords": [
        "yii2",
        "jquery",
        "assets",
        "validation",
        "widgets"
    ],
    "license": "BSD-3-Clause",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "yiisoft/yii2": "^22.0@dev"
    },
    "require-dev": {
        "maglnet/composer-require-checker": "^4.17",
        "php-forge/foxy": "^0.2",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-strict-rules": "^2.0.3",
        "phpunit/phpunit": "^11.5",
        "rector/rector": "^2.1",
        "symplify/easy-coding-standard": "^13.0",
        "yii2-extensions/phpstan": "^0.4"
    },
    "autoload": {
        "psr-4": {
            "yii\\jquery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "yii\\jquery\\tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-forge/foxy": true,
            "phpstan/extension-installer": true,
            "yiisoft/yii2-composer": true
        }
    },
    "scripts": {
        "check-dependencies": "./vendor/bin/composer-require-checker check",
        "ecs": "./vendor/bin/ecs --fix",
        "rector": "./vendor/bin/rector process",
        "static": "./vendor/bin/phpstan --memory-limit=-1",
        "tests": "./vendor/bin/phpunit"
    }
}
